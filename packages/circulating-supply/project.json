{
  "root": "packages/circulating-supply",
  "sourceRoot": "packages/circulating-supply/src",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "@nrwl/node:package",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/packages/circulating-supply",
        "tsConfig": "packages/circulating-supply/tsconfig.lib.json",
        "packageJson": "packages/circulating-supply/package.json",
        "main": "packages/circulating-supply/src/index.ts",
        "assets": ["packages/circulating-supply/*.md"]
      }
    },
    "lint": {
      "executor": "@nrwl/linter:eslint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "lintFilePatterns": ["packages/circulating-supply/**/*.ts"]
      }
    },
    "test": {
      "executor": "@nrwl/jest:jest",
      "outputs": ["coverage/packages/circulating-supply"],
      "options": {
        "jestConfig": "packages/circulating-supply/jest.config.js",
        "passWithNoTests": true
      }
    }
  },
  "tags": []
}
